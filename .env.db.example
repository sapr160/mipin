# Operator credentials for `npm run db:push` (ADR 0003): the connection strings
# for BOTH hosted Supabase projects. These are the one class of secret kept out of
# git AND out of Vercel app env — they are operator-only.
#
# Setup (once):
#   cp .env.db.example .env.db     # .env.db is gitignored
#   # fill in both URLs below
# Then `npm run db:push` loads .env.db automatically — no need to export anything.
# An already-exported value still wins, so `SUPABASE_DB_URL_PROD=… npm run db:push`
# overrides the file for a one-off.
#
# Get each from the Supabase dashboard → Project Settings → Database →
# Connection string (percent-encode any special characters in the password).
# mipin-test is the project dev/e2e point at; production is the live project.

SUPABASE_DB_URL_TEST="postgresql://postgres:[PASSWORD]@db.<test-project-ref>.supabase.co:5432/postgres"
SUPABASE_DB_URL_PROD="postgresql://postgres:[PASSWORD]@db.<prod-project-ref>.supabase.co:5432/postgres"
