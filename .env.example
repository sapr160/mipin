# Canonical public URL, used to build the Share prompt's WhatsApp link.
# Falls back to http://localhost:3000 in development / tests. Set to the
# production URL in the Vercel project.
APP_URL="https://your-domain.example"

# Ko-fi tip-jar URL. The footer link renders only when this is set; leave it
# unset to hide it.
KOFI_URL="https://ko-fi.com/yourhandle"

# --- Supabase (issue #30 / ADR 0003) ---
# Local dev and Playwright point at the `mipin-test` project; the production
# project's keys live ONLY in Vercel env vars, never here. The URL and
# publishable key are safe in the client bundle; the secret (service-role) key
# is server-only and must NEVER be prefixed NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SECRET_KEY="sb_secret_..."
