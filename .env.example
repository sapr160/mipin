# Canonical public URL, used to build the Share prompt's WhatsApp link.
# Falls back to http://localhost:3000 in development / tests. Set to the
# production URL in the Vercel project.
APP_URL="https://your-domain.example"

# Ko-fi tip-jar URL. The footer link renders only when this is set; leave it
# unset to hide it.
KOFI_URL="https://ko-fi.com/yourhandle"
